# ==============================
# Audio Denoising Using FFT
# ==============================

from scipy.io import wavfile
import numpy as np
import matplotlib.pyplot as plt
from scipy.signal import butter, filtfilt


# ------------------------------
# Load Audio File
# ------------------------------
path = "/content/drive/MyDrive/signal.wav"
fs, audio = wavfile.read(path)

# Convert stereo to mono (use left channel)
audio_one = audio[:, 0]


# ------------------------------
# Time Axis
# ------------------------------
t = np.arange(len(audio_one)) / fs


# ------------------------------
# FFT Before Filtering
# ------------------------------
N = len(audio_one)
fft_before = np.fft.fft(audio_one)
mag_before = 2 * np.abs(fft_before) / N
freq_axis = np.fft.fftfreq(N, 1 / fs)

plt.figure(figsize=(10, 4))
plt.stem(freq_axis[freq_axis >= 0], mag_before[freq_axis >= 0])
plt.title("Frequency Spectrum Before Filtering")
plt.xlabel("Frequency (Hz)")
plt.ylabel("Magnitude")
plt.grid()
plt.show()


# ------------------------------
# Low-Pass Butterworth Filter
# ------------------------------
order = 4
cut_freq = 4000  # Hz
norm_freq = cut_freq / (fs / 2)

b, a = butter(order, norm_freq, btype="low")
clean_signal = filtfilt(b, a, audio_one)


# ------------------------------
# FFT After Filtering
# ------------------------------
fft_after = np.fft.fft(clean_signal)
mag_after = 2 * np.abs(fft_after) / N

plt.figure(figsize=(10, 4))
plt.stem(freq_axis[freq_axis >= 0], mag_after[freq_axis >= 0])
plt.title("Frequency Spectrum After Filtering")
plt.xlabel("Frequency (Hz)")
plt.ylabel("Magnitude")
plt.grid()
plt.show()


# ------------------------------
# Normalize and Save Audio
# ------------------------------
clean_signal = np.nan_to_num(clean_signal)
clean_signal = clean_signal / np.max(np.abs(clean_signal))

clean_signal_int16 = (clean_signal * 32767).astype(np.int16)
wavfile.write("clean_audio.wav", fs, clean_signal_int16)